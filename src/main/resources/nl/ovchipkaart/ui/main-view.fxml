<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="10" xmlns:fx="http://javafx.com/fxml" fx:controller="nl.ovchipkaart.ui.MainController">
    <padding><Insets top="15" right="15" bottom="15" left="15"/></padding>

    <HBox spacing="15" alignment="CENTER_LEFT">
        <Label text="OV-chipkaart" styleClass="title"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="welcomeLabel" styleClass="label-bold"/>
        <Button text="Logout" onAction="#onLogout" styleClass="logout-button"/>
    </HBox>

    <HBox spacing="15" alignment="CENTER_LEFT" styleClass="card-info-bar">
        <padding><Insets top="10" right="15" bottom="10" left="15"/></padding>
        <Label text="Card:" styleClass="label-bold"/>
        <ComboBox fx:id="cardSelectorComboBox" prefWidth="220"/>
        <Label text="Balance:" styleClass="label-bold"/>
        <Label fx:id="balanceLabel" styleClass="balance"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="statusLabel" styleClass="status"/>
        <Label fx:id="cardTypeLabel" styleClass="card-type"/>
    </HBox>

    <Label fx:id="warningLabel" styleClass="warning"/>

    <TabPane fx:id="tabPane" VBox.vgrow="ALWAYS">

        <Tab text="Travel" closable="false">
            <VBox spacing="15">
                <padding><Insets top="15" right="15" bottom="15" left="15"/></padding>

                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="Station:" styleClass="label-bold"/>
                    <ComboBox fx:id="stationComboBox" prefWidth="200"/>
                    <Label text="Transport:" styleClass="label-bold"/>
                    <ComboBox fx:id="transportComboBox" prefWidth="100"/>
                </HBox>

                <Button fx:id="tapButton" text="CHECK IN" onAction="#onTap"
                        styleClass="tap-button" prefWidth="200" prefHeight="40"/>

                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="Class:" styleClass="label-bold"/>
                    <ComboBox fx:id="travelClassComboBox" prefWidth="100"/>
                    <Label text="Subscription:" styleClass="label-bold"/>
                    <ComboBox fx:id="subscriptionComboBox" prefWidth="160"/>
                </HBox>

                <Separator/>

                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Button text="Buy Day Pass (€22.50)" onAction="#onBuyDayPass"/>
                    <Label fx:id="dayPassLabel" styleClass="status"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="Missed Checkout Penalty" onAction="#onMissedCheckout"
                            styleClass="penalty-button"/>
                </HBox>
            </VBox>
        </Tab>

        <Tab text="Top Up" closable="false">
            <VBox spacing="15">
                <padding><Insets top="15" right="15" bottom="15" left="15"/></padding>

                <Label text="Manual Top-Up" styleClass="label-bold"/>
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="Amount: €"/>
                    <TextField fx:id="topUpAmountField" prefWidth="100" promptText="25.00"/>
                    <Button text="Machine (min €5)" onAction="#onMachineTopUp" styleClass="tap-button"/>
                    <Button text="Online (min €10)" onAction="#onOnlineTopUp" styleClass="tap-button"/>
                </HBox>

                <Separator/>

                <Label text="Auto Top-Up" styleClass="label-bold"/>
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <CheckBox fx:id="autoTopUpCheckBox" text="Enable auto top-up"/>
                </HBox>
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="When balance drops below €"/>
                    <TextField fx:id="autoTopUpThresholdField" prefWidth="70" promptText="10.00"/>
                    <Label text="add €"/>
                    <TextField fx:id="autoTopUpAmountField" prefWidth="70" promptText="30.00"/>
                    <Button text="Apply" onAction="#onAutoTopUpApply"/>
                </HBox>
            </VBox>
        </Tab>

        <Tab text="Transactions" closable="false">
            <VBox spacing="10">
                <padding><Insets top="15" right="15" bottom="15" left="15"/></padding>
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Button text="Refund Last Trip" onAction="#onRefund"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="monthSummaryLabel" styleClass="status"/>
                </HBox>
                <ListView fx:id="transactionList" VBox.vgrow="ALWAYS"/>
            </VBox>
        </Tab>

        <Tab text="Account" closable="false">
            <VBox spacing="15">
                <padding><Insets top="15" right="15" bottom="15" left="15"/></padding>

                <Label text="My Cards" styleClass="label-bold"/>
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Button text="Add Personal Card" onAction="#onAddPersonalCard"/>
                    <Button text="Add Anonymous Card" onAction="#onAddAnonCard"/>
                    <Button text="Remove Selected Card" onAction="#onRemoveCard" styleClass="penalty-button"/>
                </HBox>

                <Separator/>

                <Label text="Statistics" styleClass="label-bold"/>
                <Label fx:id="statsLabel" wrapText="true"/>

                <Separator/>

                <Label text="Card Info" styleClass="label-bold"/>
                <Label fx:id="cardInfoLabel" wrapText="true"/>
            </VBox>
        </Tab>

    </TabPane>

    <Label fx:id="messageLabel" styleClass="message"/>
</VBox>
